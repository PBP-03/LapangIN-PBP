# Copy to .env for local testing of production-like settings.
# On Vercel, set these as Project Settings > Environment Variables instead.

# Set to "true" to use production settings (DEBUG off, Postgres DB).
PRODUCTION=false

# Generate a fresh one for real deployments, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Set automatically by the Neon integration when added via Vercel's Storage tab.
# Format: postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Comma-separated extra hosts/origins if you attach a custom domain.
ALLOWED_HOSTS=
CSRF_TRUSTED_ORIGINS=
